{
  "compilerOptions": {
    "types": ["node"],
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    //"ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "paths": {
  "@pages/*": ["pages/*"],
  "@tests/*": ["tests/*"],
  "@utils/*": ["utils/*"],
  "@support/*": ["support/*"]
}
  },
  "include": ["tests/**/*.ts", "pages/**/*.ts", "utils/**/*.ts", "support/**/*.ts"]
}


